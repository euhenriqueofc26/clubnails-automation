{
  "outputDirectory": "public",
  "functions": {
    "api/claude.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: blob: data:;"
        }
      ]
    }
  ]
}
